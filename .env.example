# Database — Neon Postgres (required for real data; omit for in-memory demo mode)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Demo mode — set to false when wiring real data (shows empty states for new tenants)
NEXT_PUBLIC_USE_DEMO_DATA=true

# AI Gateway — at least one required for real generation
OPENROUTER_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# Optional: search-enriched generation (not yet used)
TAVILY_API_KEY=
PERPLEXITY_API_KEY=
