# Next.js app (src/app): set to false when wiring real APIs (empty UI states)
NEXT_PUBLIC_USE_DEMO_DATA=true

DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# AI Gateway — at least one required for real generation
OPENROUTER_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# Optional: search-enriched generation (not yet used)
TAVILY_API_KEY=
PERPLEXITY_API_KEY=
